{
    "name": "taraz-rooz/gold-management-system",
    "description": "سیستم مدیریت طلافروشی تراز روزانه - بازطراحی شده با معماری MVC",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Taraz Rooz Team"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers/",
            "App\\Models\\": "app/Models/",
            "App\\Core\\": "app/Core/",
            "App\\Services\\": "app/Services/",
            "App\\Helpers\\": "app/Helpers/",
            "App\\Modules\\DailyReport\\": "app/Modules/DailyReport/",
            "App\\Modules\\Income\\": "app/Modules/Income/",
            "App\\Modules\\Goals\\": "app/Modules/Goals/",
            "App\\Modules\\Tools\\": "app/Modules/Tools/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "require": {
        "php": ">=7.4"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
